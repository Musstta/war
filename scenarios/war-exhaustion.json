{
  "name": "war-exhaustion",
  "description": "Costa Rica declares war on Nicaragua at T1. Nicaragua has a pre-existing tribute obligation to Honduras of 8 Wealth/tick — signed at T1. Nicaragua's production (~5 wealth/tick) cannot cover both tribute and army upkeep, so its wealth stays at 0 every tick. Note: WAR_INSOLVENCY_UNREST_PER_TICK fires when wealthStock < 0; current engine payment logic clamps at 0 rather than going negative, so the insolvency ramp does not trigger in this scenario [known gap — deferred]. The scenario validates war under financial stress: wealth pinned at floor, army degrading over time.",
  "ticks": 15,
  "rngSeed": 42,
  "world": {
    "nations": [
      { "id": "nation_costa_rica", "name": "Costa Rica", "territories": ["costa_rica"], "armySize": 60, "wealthStock": 30 },
      { "id": "nation_nicaragua",  "name": "Nicaragua",  "territories": ["nicaragua"],  "armySize": 50, "wealthStock": 5 },
      { "id": "nation_honduras",   "name": "Honduras",   "territories": ["honduras"],   "armySize": 50, "wealthStock": 10 },
      { "id": "nation_guatemala",  "name": "Guatemala",  "territories": ["guatemala"],  "armySize": 50 },
      { "id": "nation_panama",     "name": "Panamá",     "territories": ["panama"],     "armySize": 50 }
    ]
  },
  "actions": [
    {
      "tick": 1,
      "type": "create_treaty",
      "payload": {
        "id": 1,
        "partyIds": ["nation_nicaragua", "nation_honduras"],
        "clauses": [
          {
            "type": "tribute",
            "collateral": 0,
            "payload": { "fromNationId": "nation_nicaragua", "toNationId": "nation_honduras", "amount": 8 }
          }
        ],
        "termTicks": 20,
        "collateralByParty": { "nation_nicaragua": 0, "nation_honduras": 0 }
      }
    },
    {
      "tick": 1,
      "type": "declare_war",
      "payload": { "warId": 1, "attackerId": "nation_costa_rica", "defenderId": "nation_nicaragua", "hasCasusBelli": true }
    }
  ],
  "metrics": [
    "unrest_per_territory_per_tick",
    "equilibrium_components_per_territory_per_tick",
    "stockpiles_per_nation_per_tick",
    "treaty_state_per_tick"
  ]
}
