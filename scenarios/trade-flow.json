{
  "name": "trade-flow",
  "description": "Costa Rica and Guatemala sign a 10-tick treaty at T1 with a trade clause: Guatemala sends 5 Wealth/tick to Costa Rica, sourced from the guatemala territory. Expected: 5 Wealth drains from Guatemala's general stockpile and lands in Costa Rica's stockpile each tick T1–T10. Treaty expires at T11, flows stop, both nations receive Trust bonus scaled to 10-tick duration (min(10×0.5,15)=5).",
  "ticks": 14,
  "rngSeed": 42,
  "world": {
    "nations": [
      { "id": "nation_costa_rica", "name": "Costa Rica", "territories": ["costa_rica"], "armySize": 50, "wealthStock": 20 },
      { "id": "nation_guatemala",  "name": "Guatemala",  "territories": ["guatemala"],  "armySize": 50, "wealthStock": 20 },
      { "id": "nation_honduras",   "name": "Honduras",   "territories": ["honduras"],   "armySize": 50 },
      { "id": "nation_nicaragua",  "name": "Nicaragua",  "territories": ["nicaragua"],  "armySize": 50 },
      { "id": "nation_panama",     "name": "Panamá",     "territories": ["panama"],     "armySize": 50 }
    ]
  },
  "actions": [
    {
      "tick": 1,
      "type": "create_treaty",
      "payload": {
        "id": 1,
        "partyIds": ["nation_costa_rica", "nation_guatemala"],
        "clauses": [
          { "type": "non_aggression", "collateral": 0 },
          {
            "type": "trade",
            "collateral": 5,
            "payload": {
              "resource": "wealth",
              "amount": 5,
              "fromNationId": "nation_guatemala",
              "toNationId": "nation_costa_rica",
              "sourceTerritoryId": "guatemala"
            }
          }
        ],
        "termTicks": 10,
        "collateralByParty": {
          "nation_costa_rica": 5,
          "nation_guatemala": 5
        }
      }
    }
  ],
  "metrics": [
    "stockpiles_per_nation_per_tick",
    "treaty_state_per_tick"
  ]
}
