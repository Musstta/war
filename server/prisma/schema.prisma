generator client {
  provider      = "prisma-client-js"
  // linux-musl-openssl-3.0.x = Alpine Linux (node:22-alpine uses musl + OpenSSL 3.x)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Singleton row holding the global tick counter and RNG seed.
model WorldMeta {
  id      Int @id @default(1)
  tick    Int @default(0)
  rngSeed Int @default(42)
}

model Nation {
  id                 String  @id
  name               String
  isAI               Boolean
  armySize           Int     @default(0)
  trust              Float   @default(50)
  prestige           Float   @default(0)
  popStock           Float   @default(0)
  indStock           Float   @default(0)
  wealthStock        Float   @default(0)
  mandateUsed        Int     @default(0)
  // Territory considered the nation's capital for distance-from-capital unrest.
  capitalTerritoryId String?
  // Inactivity tier: 'active' | 'dormant' | 'autopilot' | 'abandoned'. Deferred to AI sub-phase.
  inactivityTier     String  @default("active")
  // Tick of the last broken-promise event, for passive Trust recovery gating.
  lastBrokenPromiseTick Int?
  // Cumulative debt from insolvency (wealthStock < 0). Cleared via recovery skim. [PLACEHOLDER]
  debtBalance           Float @default(0)

  // ── Activity tier (Phase 6) ──────────────────────────────────────────────
  // Last time the player took any action or logged in. Null = AI nation or harness (treat as always-active).
  lastActiveAt          DateTime?
  // 'active' | 'dormant' | 'autopilot' | 'abandoned' | 'dissolved'
  activityTier          String  @default("active")
  // Tick when the nation entered Abandoned. Null until Abandoned.
  abandonedAt           DateTime?
  // Player-configurable caretaker priority queue. JSON array of strings.
  caretakerPriorities   Json    @default("[\"defense\",\"roads\",\"industry\",\"expansion\"]")
  // AI doctrine blend: { expansionist, merchant, industrialist, militarist, isolationist } summing to 1.
  // Null for human nations and caretaker-mode nations. Fixed at AI creation time.
  doctrineBlend         Json?

  // ── Prestige counters (Phase 8) ──────────────────────────────────────────
  // Cumulative count of treaties that ran to natural expiry without being broken.
  completedTreatiesKept Int     @default(0)
  // Cumulative war wins (peace deal favored this nation).
  warsWon               Int     @default(0)
  // Tick when this nation was first created (world init or fragmentation spawn).
  foundedAtTick         Int     @default(0)
  // True if this nation currently holds Dominant status (recomputed each tick).
  isDominant            Boolean @default(false)
  // Tick when the underdog unrest reduction buff expires. Null = no active buff.
  // Set when a non-Dominant nation accepts a Dominant nation's treaty.
  // [DEFERRED: wired to schema but not yet read in equilibrium computation — add in next prestige pass]
  underdogBuffExpiresAt Int?

  territories    TerritoryState[]
  actions        QueuedAction[]
  treatyParties  TreatyParty[]
  proposalsSent  Proposal[] @relation("ProposalProposer")
  proposalsReceived Proposal[] @relation("ProposalTarget")
  warsAsAttacker War[]      @relation("WarAttacker")
  warsAsDefender War[]      @relation("WarDefender")
  armies         Army[]
  territoryClaims TerritoryClaim[]
}

// One row per territory. Territory static data (name, base production, geography,
// adjacency) lives in the data file — the engine loads it at startup. Only mutable
// game state lives here.
model TerritoryState {
  id                 String  @id
  ownerId            String?
  owner              Nation? @relation(fields: [ownerId], references: [id])
  fortificationLevel Int     @default(0)
  hasRoad            Boolean @default(false)
  hasPort            Boolean @default(false)
  unrest             Float   @default(0)

  // Mutable copy of value traits — may drift over time (design doc §7.5).
  individualist Float
  progressive   Float
  militaristic  Float
  expansionist  Float

  // Phase 4 Culture: territory has crossed the revolt threshold and stops producing.
  isInRevolt            Boolean @default(false)

  // Phase 4: single construction slot for ports and forts (roads are immediate).
  constructionType      String? // 'port' | 'fort_l1' | 'fort_l2' | 'fort_l3'
  constructionTicksLeft Int?
  // Next build queued to auto-start when constructionType completes (mandate+industry pre-paid).
  pendingConstructionType String? // 'port' | 'fort_l1' | 'fort_l2' | 'fort_l3' | 'road'

  // Admin override — null means "use the static def value".
  culturalFamily String?

  // Conquest shock (design doc §12.1): decays toward 0 each tick after ownership change.
  ownershipShock Float   @default(0)
  // Tick when this territory last changed owner. null = native (never conquered).
  acquiredTick   Int?

  // Per-territory local stockpiles. Fed by production each tick.
  // Used as the draw source for trade flows and instant trades.
  // Separate from the nation's general stockpile (which holds surplus).
  localPopStock  Float @default(0)
  localIndStock  Float @default(0)
  localWltStock  Float @default(0)

  // §1.5 Territory cession: embassy present in this territory.
  // Stub — always false until embassy construction ships (Phase 8).
  // [DEFERRED: wire when embassy construction ships]
  hasEmbassy     Boolean @default(false)

  // §1.2 Population transfer shock: ticks remaining for the unrest spike.
  populationTransferShockTicksLeft Int @default(0)
}

// Actions queued during the Main or Preparation phase, resolved atomically at the
// midnight tick. Rows are deleted after each tick inside the same transaction.
// (design doc §17: "store queued intents, not immediate mutations")
model QueuedAction {
  id         Int      @id @default(autoincrement())
  nationId   String
  nation     Nation   @relation(fields: [nationId], references: [id])
  phase      String   // 'main' | 'prep'
  type       String
  payload    Json
  tickQueued Int
  createdAt  DateTime @default(now())
}

// Append-only world history. Emitted by resolveTick; see design doc §16.
model EventLog {
  id      Int    @id @default(autoincrement())
  tick    Int
  message String

  @@index([tick])
}

// ── Diplomacy ─────────────────────────────────────────────────────────────────

// A Proposal is a take-it-or-leave-it treaty offer (v1). Stores the full proposed
// clause set so the recipient can read exactly what they're accepting.
// parentProposalId is null in v1 but reserved for future counter-offer chains
// (design doc §8.3). status: 'pending' | 'accepted' | 'declined' | 'expired'
model Proposal {
  id                 Int      @id @default(autoincrement())
  proposerId         String
  proposer           Nation   @relation("ProposalProposer", fields: [proposerId], references: [id])
  targetId           String
  target             Nation   @relation("ProposalTarget", fields: [targetId], references: [id])
  status             String   @default("pending") // 'pending' | 'accepted' | 'declined' | 'expired'
  termTicks          Int
  proposerCollateral Float    @default(0) // each party's share; pooled into Treaty on accept
  targetCollateral   Float    @default(0)
  tickProposed       Int
  expiresAtTick      Int      // tickProposed + PROPOSAL_EXPIRY_TICKS
  parentProposalId   Int?     // null in v1; reserved for counter-offer chains
  treaty             Treaty?

  clauses ProposalClause[]
}

// Each clause in a proposal. type: 'non_aggression' | 'tribute' | 'trade' | 'military_access'
//   | 'defense_pact' | 'objective'
// payload holds clause-specific params; for objective clauses the full ObjectiveClause
// fields are stored here too (objectiveType, targetNationId, targetTerritoryId,
// deadlineTicks, responsibleParty). status is always 'pending' at proposal time.
model ProposalClause {
  id         Int      @id @default(autoincrement())
  proposalId Int
  proposal   Proposal @relation(fields: [proposalId], references: [id])
  type       String
  collateral Float    @default(0) // [PLACEHOLDER] per-clause collateral
  payload    Json     @default("{}")
}

// An active (or recently terminated) treaty. Created when a Proposal is accepted.
// status: 'active' | 'degraded' | 'broken' | 'expired'
// totalCollateral = sum of all per-clause collateral values (design doc §8.4).
model Treaty {
  id              Int      @id @default(autoincrement())
  proposalId      Int      @unique
  proposal        Proposal @relation(fields: [proposalId], references: [id])
  status          String   @default("active")
  termTicks       Int
  tickStarted     Int
  tickEnds        Int      // tickStarted + termTicks
  totalCollateral Float    @default(0)
  breakerNationId String?  // set when status = 'broken'

  parties TreatyParty[]
  clauses TreatyClause[]
}

// Per-party treaty record: each nation's collateral deposit + degradation escrow state.
// refundRemaining / refundStartTick: active partner's collateral returned over 3 ticks.
// escrowAmount / escrowStartTick: inactive player's collateral held until return.
model TreatyParty {
  id                  Int    @id @default(autoincrement())
  treatyId            Int
  treaty              Treaty @relation(fields: [treatyId], references: [id])
  nationId            String
  nation              Nation @relation(fields: [nationId], references: [id])
  collateralDeposited Float  @default(0)
  escrowAmount        Float  @default(0)
  escrowStartTick     Int?
  refundRemaining     Float  @default(0)
  refundStartTick     Int?

  @@unique([treatyId, nationId])
}

// Each clause in an active treaty (mirrors ProposalClause).
// clauseIndex is stable across the treaty lifetime — used for per-clause degradation.
// clauseStatus: 'active' | 'degraded' | 'breached'
// missedPayments: consecutive ticks where a trade clause could not deduct from source territory.
model TreatyClause {
  id             Int    @id @default(autoincrement())
  treatyId       Int
  treaty         Treaty @relation(fields: [treatyId], references: [id])
  clauseIndex    Int    @default(0)
  type           String
  collateral     Float  @default(0)
  payload        Json   @default("{}")
  clauseStatus   String @default("active") // 'active' | 'degraded' | 'breached'
  missedPayments Int    @default(0)        // consecutive missed trade payments

  tradeRoute      TradeRoute?
  objectiveClause ObjectiveClause?
}

// Objective clause — one per TreatyClause where type === 'objective'.
// objectiveType: 'build_road_connection' | 'build_port' | 'maintain_peace'
//                | 'joint_invasion' [STUB] | 'attack_player' [STUB]
// status: 'pending' | 'met' | 'failed' | 'waived'
// responsibleParty: 'partyA' | 'partyB' | 'both'
model ObjectiveClause {
  id                Int          @id @default(autoincrement())
  treatyClauseId    Int          @unique
  treatyClause      TreatyClause @relation(fields: [treatyClauseId], references: [id])
  objectiveType     String       // see ObjectiveType enum in engine
  targetNationId    String?      // for attack_player, joint_invasion
  targetTerritoryId String?      // for build_port, build_road_connection
  deadlineTicks     Int          // ticks from treaty signing
  status            String       @default("pending") // 'pending' | 'met' | 'failed' | 'waived'
  responsibleParty  String       @default("partyA")  // 'partyA' | 'partyB' | 'both'
}

// ── War ───────────────────────────────────────────────────────────────────────

// An active or recently ended war between two nations.
// status: 'active' | 'peace_negotiation' | 'ended'
// type: 'conquest' | 'raid' — raid behavior identical to conquest in v1 [STUB]
// occupiedTerritories: JSON array of { territoryId, occupyingNationId, siegeProgress, siegeStartTick }
// pendingPeaceDeal: null until peace_negotiation; JSON blob (Prompt 2)
model War {
  id                    Int      @id @default(autoincrement())
  attackerId            String
  attacker              Nation   @relation("WarAttacker", fields: [attackerId], references: [id])
  defenderId            String
  defender              Nation   @relation("WarDefender", fields: [defenderId], references: [id])
  type                  String   @default("conquest")  // 'conquest' | 'raid'
  hasCasusBelli         Boolean  @default(true)
  status                String   @default("active")    // 'active' | 'peace_negotiation' | 'ended'
  startTick             Int
  declaredTick          Int      // same as startTick; kept separate for no-CB duration tracking
  endTick               Int?
  occupiedTerritories   Json     @default("[]")         // OccupiedTerritory[]
  pendingPeaceDeal      Json?                            // PeaceDeal | null
  // Per-nation exhaustion from a declined peace proposal: { nationId: exhaustionEndsAtTick }
  exhaustionByNation    Json     @default("{}")
}

// ── Army (positioned military unit) ──────────────────────────────────────────
// Replaces flat armySize on Nation. Each nation may have multiple armies (split/merge stubbed).
// status: 'stationed' | 'moving' | 'besieging' | 'occupying'

model Army {
  id                      Int     @id @default(autoincrement())
  nationId                String
  nation                  Nation  @relation(fields: [nationId], references: [id])
  territoryId             String
  size                    Int
  status                  String  @default("stationed")
  destinationTerritoryId  String?  // non-null while moving
  movedThisTick           Boolean @default(false)

  // §1.3 Multi-tick movement model.
  // transitPath: ordered territory IDs remaining on the journey (destination included, origin excluded).
  transitPath             Json    @default("[]")
  // transitTicksRemaining: ticks until next step on transitPath.
  transitTicksRemaining   Int     @default(0)

  @@index([nationId])
  @@index([territoryId])
}

// §1.4 TerritoryModifier: temporary (or permanent) effect on a territory.
// Sources: barricade, war-torn, events, edicts.
model TerritoryModifier {
  id                    Int     @id @default(autoincrement())
  territoryId           String
  source                String  // 'barricade' | 'war_torn' | 'event' | ...
  movementMultiplier    Float   @default(1.0)
  productionMultiplier  Float   @default(1.0)
  unrestEquilibriumAdj  Float   @default(0.0)
  driftRateMultiplier   Float   @default(1.0)
  defenseBonus          Float   @default(0.0)
  startTick             Int
  durationTicks         Int?    // null = permanent
  expiresAtTick         Int?    // null = permanent

  @@index([territoryId])
  @@index([expiresAtTick])
}

// §1.4 Border skirmish event record.
model BorderSkirmish {
  id              Int     @id @default(autoincrement())
  tick            Int
  territoryId     String
  nationAId       String
  nationBId       String
  armySizeA       Int
  armySizeB       Int
  winnerId        String?
  fullCasusBelli  Boolean @default(false)

  @@index([tick])
  @@index([nationAId, nationBId])
}

// §1.9 Maintain_peace history: track consecutive treaty signing per nation-pair.
model TreatyHistory {
  id            Int     @id @default(autoincrement())
  nationAId     String
  nationBId     String
  clauseType    String  // 'maintain_peace' (may extend to other types)
  signedAtTick  Int

  @@index([nationAId, nationBId, clauseType])
}

// ── Territory Claim ────────────────────────────────────────────────────────────
// A nation's claim on an unclaimed territory. Pacification completes when
// pacificationProgress >= PACIFICATION_THRESHOLD.

model TerritoryClaim {
  id                    Int    @id @default(autoincrement())
  nationId              String
  nation                Nation @relation(fields: [nationId], references: [id])
  territoryId           String
  claimedAtTick         Int
  pacificationProgress  Float  @default(0)

  @@index([nationId])
  @@index([territoryId])
}

// ── Federation (scaffolding — visibility grant only, no actions yet) ──────────
// Federations grant Clear visibility between member nations.
// No federation actions exist yet — tables created for computeVisibility.
// status: 'active' | 'dissolved'

model Federation {
  id            Int               @id @default(autoincrement())
  name          String
  foundedAtTick Int
  status        String            @default("active") // 'active' | 'dissolved'
  members       FederationMember[]
}

// role: 'founder' | 'member'
model FederationMember {
  id           Int        @id @default(autoincrement())
  federationId Int
  federation   Federation @relation(fields: [federationId], references: [id])
  nationId     String
  joinedAtTick Int
  role         String     @default("member") // 'founder' | 'member'

  @@unique([federationId, nationId])
  @@index([nationId])
}

// ── Trade ─────────────────────────────────────────────────────────────────────

// A pending instant trade offer (no term, no collateral).
// status: 'pending' | 'accepted' | 'declined' | 'expired'
// Resource pre-deducted from sourceTerritoryId's local stockpile at queue time; refunded on non-accept.
model InstantTrade {
  id                Int    @id @default(autoincrement())
  proposerNationId  String
  targetNationId    String
  resource          String // 'population' | 'industry' | 'wealth'
  amount            Float
  sourceTerritoryId String
  status            String @default("pending")
  tickProposed      Int
  expiresAtTick     Int    // tickProposed + 1 (expires after 1 tick if not accepted this tick)
}

// Route object for a trade clause (design doc §14A.6: store routes as real objects).
// path is a JSON array of territory IDs from source to destination.
// pathStale: true when any territory on the path changed owner since pathComputedAtTick.
// capacity and friction are [PLACEHOLDER] — not yet computed.
model TradeRoute {
  id                   Int          @id @default(autoincrement())
  treatyClauseId       Int          @unique
  treatyClause         TreatyClause @relation(fields: [treatyClauseId], references: [id])
  sourceTerritoryId    String
  destinationNationId  String
  path                 Json         @default("[]")  // territory ID array
  pathComputedAtTick   Int
  pathStale            Boolean      @default(false)
  capacity             Float?       // [PLACEHOLDER] max flow per tick
  friction             Float?       // [PLACEHOLDER] fraction lost in transit
  isSeaRoute           Boolean      @default(false)
}

// ── War Council ───────────────────────────────────────────────────────────────
// One council per side per war. Created when a war starts.
// memberNationIds: JSON array of nation IDs on this side.
// side: 'attacker' | 'defender'

model WarCouncil {
  id               Int    @id @default(autoincrement())
  warId            Int
  side             String // 'attacker' | 'defender'
  memberNationIds  Json   @default("[]")

  queuedActions    CouncilQueuedAction[]

  @@index([warId])
}

// Read-only mirror of military actions queued by council members for the current tick.
// Written when a member queues attack_territory, move_army, or retreat_army.
// Deleted at tick resolution after actions resolve.
// actionType: 'attack_territory' | 'move_army' | 'retreat_army'
// targetTerritoryId: the territory being attacked/moved-to/retreated-from

model CouncilQueuedAction {
  id                  Int        @id @default(autoincrement())
  councilId           Int
  council             WarCouncil @relation(fields: [councilId], references: [id])
  nationId            String
  actionType          String
  targetTerritoryId   String?
  tick                Int

  @@index([councilId])
}

// ── Prestige History ──────────────────────────────────────────────────────────
// One row per nation per tick. Used for sparklines and secondary stat queries.
// Written by saveWorldState after Prestige is computed.

model PrestigeHistory {
  id        Int    @id @default(autoincrement())
  nationId  String
  tick      Int
  prestige  Float  @default(0)

  @@index([nationId, tick])
}

// ── Embassy (§1.6) ────────────────────────────────────────────────────────────
// One embassy per bilateral (ownerNationId, hostTerritoryId) pair.
// status: 'proposed' | 'under_construction' | 'active' | 'expelled' | 'destroyed'
// A proposal is created by propose_embassy. The owner nation then queues build_embassy
// to begin construction. constructionTicksLeft decrements each tick until active.
// The host nation may expel (sets status='expelled') at any time.
// If hostTerritoryId changes owner, status → 'destroyed'.

model Embassy {
  id                      Int    @id @default(autoincrement())
  ownerNationId           String
  hostTerritoryId         String
  status                  String @default("proposed") // EmbassyStatus
  constructionTicksLeft   Int    @default(0)
  startedAtTick           Int

  @@unique([ownerNationId, hostTerritoryId])
  @@index([hostTerritoryId])
  @@index([ownerNationId])
}
