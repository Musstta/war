generator client {
  provider      = "prisma-client-js"
  // linux-musl-openssl-3.0.x = Alpine Linux (node:22-alpine uses musl + OpenSSL 3.x)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multi-world game registry (v0.34) ─────────────────────────────────────────
// One row per game instance. The legacy single world uses id='legacy-world'.
// tickIntervalSeconds is a placeholder — scheduling is still hardcoded to cron.
model Game {
  id                  String   @id
  name                String
  hostUserId          Int?
  maxPlayers          Int      @default(5)
  status              String   @default("lobby") // 'lobby' | 'territory_selection' | 'active' | 'ended'
  createdAt           DateTime @default(now())
  tickIntervalSeconds Int      @default(86400)
  lastTickAt          DateTime?
  endedAt             DateTime?
  endReason           String?  // 'win_condition' | 'host_ended'
  removedSlots        Json     @default("[]") // Int[] of slot indices resolved as removed
  aiSlots             Json     @default("[]") // Int[] of slot indices resolved as ai
  // Set when host starts game (transitions lobby → territory_selection). AFK deadline = this + tickIntervalSeconds.
  territorySelectionStartedAt DateTime?

  memberships         GameMembership[]
  ffVotes             FastForwardVote[]
  territoryCandidates TerritoryCandidate[]
}

// One row per player slot in a game. slotIndex 0 = host.
model GameMembership {
  id                   Int      @id @default(autoincrement())
  gameId               String
  game                 Game     @relation(fields: [gameId], references: [id])
  userId               Int
  user                 User     @relation(fields: [userId], references: [id])
  slotIndex            Int
  nationId             String?
  joinedAt             DateTime @default(now())
  // v0.37: territory selection state
  rerollUsed           Boolean  @default(false)
  confirmedTerritoryId String?

  @@unique([gameId, userId])
  @@unique([gameId, slotIndex])
  @@index([gameId])
  @@index([userId])
}

// One row per player vote to fast-forward the current tick.
// Cleared after each tick fires. Unique per player per game.
model FastForwardVote {
  id         Int      @id @default(autoincrement())
  gameId     String
  game       Game     @relation(fields: [gameId], references: [id])
  userId     Int
  tickNumber Int
  votedAt    DateTime @default(now())

  @@unique([gameId, userId])
  @@index([gameId])
}

// One row per candidate territory shown to a player during territory_selection phase.
// Each player gets 3 candidates per roll (slotIndex 0, 1, 2). Confirmed = player locked in.
model TerritoryCandidate {
  id          Int      @id @default(autoincrement())
  gameId      String
  game        Game     @relation(fields: [gameId], references: [id])
  userId      Int
  slotIndex   Int      // 0, 1, or 2 — which candidate slot this is
  territoryId String   // raw def.id (no gameId prefix)
  confirmed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([gameId])
  @@index([gameId, userId])
}

// ── Auth: User table (v0.34) ──────────────────────────────────────────────────
// One row per registered user. username is globally unique across all games.
// passwordHash: bcrypt hash of the password (cost factor 12).
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  sessions     UserSession[]
  memberships  GameMembership[]
}

// ── Auth: Session table (v0.34) ───────────────────────────────────────────────
// Token-based sessions. The token is a random hex string stored in the
// war_session cookie (signed). Sessions expire after 30 days.
model UserSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  nationId  String?  // the nationId this session is linked to (derived from PLAYERS mapping)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([token])
}

// Singleton row holding the global tick counter and RNG seed.
model WorldMeta {
  id      Int    @id @default(1)
  tick    Int    @default(0)
  rngSeed Int    @default(42)
  gameId  String @default("legacy-world")
}

model Nation {
  id                 String  @id
  gameId             String  @default("legacy-world")
  name               String
  isAI               Boolean
  armySize           Int     @default(0)
  trust              Float   @default(50)
  prestige           Float   @default(0)
  popStock           Float   @default(0)
  indStock           Float   @default(0)
  wealthStock        Float   @default(0)
  mandateUsed        Int     @default(0)
  capitalTerritoryId String?
  inactivityTier     String  @default("active")
  lastBrokenPromiseTick Int?
  debtBalance           Float @default(0)

  lastActiveAt          DateTime?
  activityTier          String  @default("active")
  abandonedAt           DateTime?
  caretakerPriorities   Json    @default("[\"defense\",\"roads\",\"industry\",\"expansion\"]")
  doctrineBlend         Json?

  completedTreatiesKept Int     @default(0)
  warsWon               Int     @default(0)
  foundedAtTick         Int     @default(0)
  isDominant            Boolean @default(false)
  underdogBuffExpiresAt Int?

  territories    TerritoryState[]
  actions        QueuedAction[]
  treatyParties  TreatyParty[]
  proposalsSent  Proposal[] @relation("ProposalProposer")
  proposalsReceived Proposal[] @relation("ProposalTarget")
  warsAsAttacker War[]      @relation("WarAttacker")
  warsAsDefender War[]      @relation("WarDefender")
  armies         Army[]
  territoryClaims TerritoryClaim[]

  @@index([gameId])
}

model TerritoryState {
  id                 String  @id
  gameId             String  @default("legacy-world")
  ownerId            String?
  owner              Nation? @relation(fields: [ownerId], references: [id])
  fortificationLevel Int     @default(0)
  hasRoad            Boolean @default(false)
  hasPort            Boolean @default(false)
  portLevel          Int     @default(1)
  hasMarket          Boolean @default(false)
  unrest             Float   @default(0)

  individualist Float
  progressive   Float
  militaristic  Float
  expansionist  Float

  isInRevolt            Boolean @default(false)

  constructionType      String?
  constructionTicksLeft Int?
  pendingConstructionType String?

  culturalFamily String?

  ownershipShock Float   @default(0)
  acquiredTick   Int?

  localPopStock  Float @default(0)
  localIndStock  Float @default(0)
  localWltStock  Float @default(0)

  hasEmbassy     Boolean @default(false)

  populationTransferShockTicksLeft Int @default(0)

  @@index([gameId])
}

model QueuedAction {
  id         Int      @id @default(autoincrement())
  gameId     String   @default("legacy-world")
  nationId   String
  nation     Nation   @relation(fields: [nationId], references: [id])
  phase      String
  type       String
  payload    Json
  tickQueued Int
  createdAt  DateTime @default(now())

  @@index([gameId])
}

model EventLog {
  id      Int    @id @default(autoincrement())
  gameId  String @default("legacy-world")
  tick    Int
  message String

  @@index([tick])
  @@index([gameId])
}

// ── Diplomacy ─────────────────────────────────────────────────────────────────

model Proposal {
  id                 Int      @id @default(autoincrement())
  gameId             String   @default("legacy-world")
  proposerId         String
  proposer           Nation   @relation("ProposalProposer", fields: [proposerId], references: [id])
  targetId           String
  target             Nation   @relation("ProposalTarget", fields: [targetId], references: [id])
  status             String   @default("pending")
  termTicks          Int
  proposerCollateral Float    @default(0)
  targetCollateral   Float    @default(0)
  tickProposed       Int
  expiresAtTick      Int
  parentProposalId   Int?
  treaty             Treaty?

  clauses ProposalClause[]

  @@index([gameId])
}

model ProposalClause {
  id         Int      @id @default(autoincrement())
  proposalId Int
  proposal   Proposal @relation(fields: [proposalId], references: [id])
  type       String
  collateral Float    @default(0)
  payload    Json     @default("{}")
}

model Treaty {
  id              Int      @id @default(autoincrement())
  gameId          String   @default("legacy-world")
  proposalId      Int      @unique
  proposal        Proposal @relation(fields: [proposalId], references: [id])
  status          String   @default("active")
  termTicks       Int
  tickStarted     Int
  tickEnds        Int
  totalCollateral Float    @default(0)
  breakerNationId String?

  parties TreatyParty[]
  clauses TreatyClause[]

  @@index([gameId])
}

model TreatyParty {
  id                  Int    @id @default(autoincrement())
  treatyId            Int
  treaty              Treaty @relation(fields: [treatyId], references: [id])
  nationId            String
  nation              Nation @relation(fields: [nationId], references: [id])
  collateralDeposited Float  @default(0)
  escrowAmount        Float  @default(0)
  escrowStartTick     Int?
  refundRemaining     Float  @default(0)
  refundStartTick     Int?

  @@unique([treatyId, nationId])
}

model TreatyClause {
  id             Int    @id @default(autoincrement())
  treatyId       Int
  treaty         Treaty @relation(fields: [treatyId], references: [id])
  clauseIndex    Int    @default(0)
  type           String
  collateral     Float  @default(0)
  payload        Json   @default("{}")
  clauseStatus   String @default("active")
  missedPayments Int    @default(0)

  tradeRoute           TradeRoute?
  objectiveClause      ObjectiveClause?
  tradeRouteAgreement  TradeRouteAgreement?
}

model ObjectiveClause {
  id                Int          @id @default(autoincrement())
  treatyClauseId    Int          @unique
  treatyClause      TreatyClause @relation(fields: [treatyClauseId], references: [id])
  objectiveType     String
  targetNationId    String?
  targetTerritoryId String?
  deadlineTicks     Int
  status            String       @default("pending")
  responsibleParty  String       @default("partyA")
}

// ── War ───────────────────────────────────────────────────────────────────────

model War {
  id                    Int      @id @default(autoincrement())
  gameId                String   @default("legacy-world")
  attackerId            String
  attacker              Nation   @relation("WarAttacker", fields: [attackerId], references: [id])
  defenderId            String
  defender              Nation   @relation("WarDefender", fields: [defenderId], references: [id])
  type                  String   @default("conquest")
  hasCasusBelli         Boolean  @default(true)
  status                String   @default("active")
  startTick             Int
  declaredTick          Int
  endTick               Int?
  occupiedTerritories   Json     @default("[]")
  pendingPeaceDeal      Json?
  exhaustionByNation    Json     @default("{}")

  @@index([gameId])
}

model Army {
  id                      Int     @id @default(autoincrement())
  gameId                  String  @default("legacy-world")
  nationId                String
  nation                  Nation  @relation(fields: [nationId], references: [id])
  territoryId             String
  size                    Int
  status                  String  @default("stationed")
  destinationTerritoryId  String?
  movedThisTick           Boolean @default(false)

  transitPath             Json    @default("[]")
  transitTicksRemaining   Int     @default(0)

  @@index([nationId])
  @@index([territoryId])
  @@index([gameId])
}

model TerritoryModifier {
  id                    Int     @id @default(autoincrement())
  gameId                String  @default("legacy-world")
  territoryId           String
  source                String
  movementMultiplier    Float   @default(1.0)
  productionMultiplier  Float   @default(1.0)
  unrestEquilibriumAdj  Float   @default(0.0)
  driftRateMultiplier   Float   @default(1.0)
  defenseBonus          Float   @default(0.0)
  startTick             Int
  durationTicks         Int?
  expiresAtTick         Int?

  @@index([territoryId])
  @@index([expiresAtTick])
  @@index([gameId])
}

model BorderSkirmish {
  id              Int     @id @default(autoincrement())
  gameId          String  @default("legacy-world")
  tick            Int
  territoryId     String
  nationAId       String
  nationBId       String
  armySizeA       Int
  armySizeB       Int
  winnerId        String?
  fullCasusBelli  Boolean @default(false)

  @@index([tick])
  @@index([nationAId, nationBId])
  @@index([gameId])
}

model TreatyHistory {
  id            Int     @id @default(autoincrement())
  gameId        String  @default("legacy-world")
  nationAId     String
  nationBId     String
  clauseType    String
  signedAtTick  Int

  @@index([nationAId, nationBId, clauseType])
  @@index([gameId])
}

model TerritoryClaim {
  id                    Int    @id @default(autoincrement())
  gameId                String @default("legacy-world")
  nationId              String
  nation                Nation @relation(fields: [nationId], references: [id])
  territoryId           String
  claimedAtTick         Int
  pacificationProgress  Float  @default(0)

  @@index([nationId])
  @@index([territoryId])
  @@index([gameId])
}

model Federation {
  id            Int               @id @default(autoincrement())
  gameId        String            @default("legacy-world")
  name          String
  foundedAtTick Int
  status        String            @default("active")
  members       FederationMember[]

  @@index([gameId])
}

model FederationMember {
  id           Int        @id @default(autoincrement())
  federationId Int
  federation   Federation @relation(fields: [federationId], references: [id])
  nationId     String
  joinedAtTick Int
  role         String     @default("member")

  @@unique([federationId, nationId])
  @@index([nationId])
}

// ── Trade ─────────────────────────────────────────────────────────────────────

model InstantTrade {
  id                Int    @id @default(autoincrement())
  gameId            String @default("legacy-world")
  proposerNationId  String
  targetNationId    String
  resource          String
  amount            Float
  sourceTerritoryId String
  status            String @default("pending")
  tickProposed      Int
  expiresAtTick     Int

  @@index([gameId])
}

model TradeRoute {
  id                   Int          @id @default(autoincrement())
  gameId               String       @default("legacy-world")
  treatyClauseId       Int          @unique
  treatyClause         TreatyClause @relation(fields: [treatyClauseId], references: [id])
  sourceTerritoryId    String
  destinationNationId  String
  path                 Json         @default("[]")
  pathComputedAtTick   Int
  pathStale            Boolean      @default(false)
  capacity             Float?
  friction             Float?
  isSeaRoute           Boolean      @default(false)

  @@index([gameId])
}

model WarCouncil {
  id               Int    @id @default(autoincrement())
  gameId           String @default("legacy-world")
  warId            Int
  side             String
  memberNationIds  Json   @default("[]")

  queuedActions    CouncilQueuedAction[]

  @@index([warId])
  @@index([gameId])
}

model CouncilQueuedAction {
  id                  Int        @id @default(autoincrement())
  councilId           Int
  council             WarCouncil @relation(fields: [councilId], references: [id])
  nationId            String
  actionType          String
  targetTerritoryId   String?
  tick                Int

  @@index([councilId])
}

model PrestigeHistory {
  id        Int    @id @default(autoincrement())
  gameId    String @default("legacy-world")
  nationId  String
  tick      Int
  prestige  Float  @default(0)

  @@index([nationId, tick])
  @@index([gameId])
}

model Embassy {
  id                      Int    @id @default(autoincrement())
  gameId                  String @default("legacy-world")
  ownerNationId           String
  hostTerritoryId         String
  status                  String @default("proposed")
  constructionTicksLeft   Int    @default(0)
  startedAtTick           Int

  @@unique([ownerNationId, hostTerritoryId])
  @@index([hostTerritoryId])
  @@index([ownerNationId])
  @@index([gameId])
}

model TradeRouteAgreement {
  id                     Int    @id @default(autoincrement())
  gameId                 String @default("legacy-world")
  treatyClauseId         Int?   @unique
  treatyClause           TreatyClause? @relation(fields: [treatyClauseId], references: [id])
  ownerNationId          String
  partnerNationId        String?
  type                   String
  sourceTerritoryId      String
  destinationTerritoryId String
  path                   Json   @default("[]")
  pathComputedAtTick     Int
  portLevel              Int    @default(1)
  baseCapacity           Float
  currentCapacity        Float
  growthCap              Float
  cyclesCompleted        Int    @default(0)
  profitMultiplier       Float  @default(1.0)
  upkeepRate             Float  @default(0.1)
  status                 String @default("active")
  startedAtTick          Int

  shipments              TradeShipment[]

  @@index([ownerNationId])
  @@index([partnerNationId])
  @@index([sourceTerritoryId])
  @@index([destinationTerritoryId])
  @@index([gameId])
}

model TradeShipment {
  id                    Int                 @id @default(autoincrement())
  routeId               Int
  route                 TradeRouteAgreement @relation(fields: [routeId], references: [id])
  path                  Json   @default("[]")
  transitTicksRemaining Int    @default(1)
  cargoAmount           Float
  cargoResource         String @default("wealth")
  direction             String @default("forward")
  departedAtTick        Int

  @@index([routeId])
}
